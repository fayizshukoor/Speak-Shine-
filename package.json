{
  "name": "speak-shine-webapp",
  "version": "1.0.0",
  "description": "Speak & Shine - AI-powered speech analysis platform",
  "main": "api/server.js",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node --max-old-space-size=4096 --expose-gc api/server.js",
    "start:api": "node api/server.js",
    "dev:backend": "node api/server.js",
    "dev:api": "node api/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:infisical": "infisical run -- npm run dev:backend",
    "setup": "node scripts/setup.cjs",
    "build": "cd frontend && npm install --prefer-offline --no-audit --no-fund && npm run build",
    "build:frontend": "cd frontend && npm ci --prefer-offline --no-audit --no-fund && npm run build",
    "test": "vitest run",
    "test:daily-reset": "node backend/services/scheduler/test-daily-reset-standalone.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "argon2": "^0.41.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "file-type": "^21.3.4",
    "groq-sdk": "^0.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.10.0",
    "mongoose": "^8.3.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.3",
    "socket.io": "^4.8.3"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "devDependencies": {
    "fast-check": "^4.7.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  },
  "directories": {
    "doc": "docs"
  },
  "author": "",
  "license": "ISC"
}
