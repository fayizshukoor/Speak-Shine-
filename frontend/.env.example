# frontend/.env.example — public Vite env variables
# These values are visible in the browser. NEVER put secrets here.

# Base API URL used by the frontend to call backend APIs
VITE_API_URL=http://localhost:3001

# Example optional public values
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=

# Usage: copy to frontend/.env.local and edit locally.
#   cp frontend/.env.example frontend/.env.local
# Copy to frontend/.env.local for local development:
#   cp .env.example .env.local        (Linux / macOS)
#   copy .env.example .env.local      (Windows)

# Use Vite proxy (recommended) — requests go to localhost:5173/api → backend :3001
VITE_API_URL=/api

# Or talk to the API directly (no proxy):
# VITE_API_URL=http://localhost:3001/api

# Optional — live sessions
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
