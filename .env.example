# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to create a local `.env` and fill real values
# (backend `.env`) and `frontend/.env.local` (frontend Vite env) as needed.
# Keep secrets out of Git: DO NOT commit your local `.env` files.
# Infisical users can also keep secret values in Infisical and run the
# backend with `infisical run -- npm run dev:backend`.
# ─────────────────────────────────────────────────────────────────────────────

# --------------------------- Backend (private) -------------------------------
# Copy these to your local `.env` at the project root (backend uses these)
MONGO_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server settings
NODE_ENV=development
PORT=3001
API_PORT=3001
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Redis (optional)
REDIS_URL=

# Cloudflare R2 (video storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_ENDPOINT=

# AI keys (private)
GROQ_API_KEY=
GROQ_API_KEYS=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# LiveKit (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Feature flags / tuning
ENABLE_CODEC_VALIDATION=false
ENABLE_VIRUS_SCAN=false
ENABLE_CONTENT_MODERATION=false
TRANSCRIBE_TIMEOUT_MS=240000
SPEECH_TIMEOUT_MS=120000
VISUAL_TIMEOUT_MS=240000

# WhatsApp / Optional
OWNER_NUMBER=
TARGET_GROUP=
TEST_MODE=false

# --------------------------- Frontend (public) ------------------------------
# Vite requires public vars to start with VITE_ — these values are visible in
# the browser and must NEVER contain secrets (API keys, DB creds, etc.).
# Put these in `frontend/.env.local` or `frontend/.env` (local only).
VITE_API_URL=http://localhost:3001
VITE_SENTRY_DSN=
VITE_OTHER_PUBLIC=

# --------------------------- How to use -------------------------------------
# 1. Backend: copy this file to `.env` at the repo root and fill in private
#    values. Restart the server when values change.
# 2. Frontend: copy `frontend/.env.example` to `frontend/.env.local` (or
#    `frontend/.env`) and fill PUBLIC values. Restart dev server.
# 3. Never commit your `.env` or frontend local env files. Use `.env.example`
#    to document required variables for collaborators.
# ---------------------------------------------------------------------------
